datasource db {
  provider = "postgresql"
  schemas  = ["public", "auth"]
}

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

/// Supabase-managed. Only `id` is modeled so Prisma can resolve the profiles FK.
model auth_users {
  id       String    @id @db.Uuid
  profiles profiles?

  @@map("users")
  @@schema("auth")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model meals {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String             @default("") @db.VarChar
  slug             String?            @unique @map("slug") @db.VarChar
  description      String             @default("") @db.VarChar
  imageUrl         String             @default("") @map("image_url") @db.VarChar
  type             String             @default("") @db.VarChar
  composition      Json?
  meals_plan_items meals_plan_items[]

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model meals_plan_items {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  meals_plan_id String?      @db.Uuid
  meal_id       String?      @db.Uuid
  meals         meals?       @relation(fields: [meal_id], references: [id], onDelete: Cascade)
  meals_plans   meals_plans? @relation(fields: [meals_plan_id], references: [id], onDelete: Cascade)

  @@map("meals-plan-items")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model meals_plans {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String             @db.Uuid
  date             String             @db.VarChar
  meals_plan_items meals_plan_items[]

  @@map("meals-plans")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model profiles {
  id           String        @id(map: "admins_pkey") @db.Uuid
  createdAt    String        @map("created_at") @db.VarChar
  email        String        @unique(map: "admins_email_key") @default("") @db.VarChar
  name         String        @default("") @db.VarChar
  role         String        @default("") @db.VarChar
  auth_users   auth_users    @relation(fields: [id], references: [id], onDelete: Cascade)
  public_users public_users?

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model public_users {
  id            String    @id @db.Uuid
  createdAt     String    @map("created_at") @db.VarChar
  updatedAt     String?   @map("updated_at") @db.VarChar
  name          String    @default("") @db.VarChar
  email         String    @unique @default("") @db.VarChar
  age           Int       @default(0)
  height        Int       @default(0)
  weight        Int       @default(0)
  avatarUrl     String?   @map("avatar_url") @db.VarChar
  gender        String    @default("") @db.VarChar
  activityLevel String    @default("") @map("activity_level") @db.VarChar
  profiles      profiles  @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("users")
  @@schema("public")
}
